### Variables
@host = http://localhost:8080
@phoneA = +33600000001
@phoneB = +33600000002
@phoneC = +33600000003

### 1. Register user A
POST {{host}}/users/register
Content-Type: application/json

{
  "username": "olfa",
  "password": "test123",
  "phoneNumber": "{{phoneA}}",
  "email": "olfa@test.com"
}

### 2. Register user B
POST {{host}}/users/register
Content-Type: application/json

{
  "username": "alice",
  "password": "test123",
  "phoneNumber": "{{phoneB}}",
  "email": "alice@test.com"
}

### 3. Login as user A (stores token in {{token}})
POST {{host}}/users/login
Content-Type: application/json

{
  "phoneNumber": "{{phoneA}}",
  "password": "test123"
}

> {%
    client.global.set("token", response.body);
%}

### 4. Send friend request A -> B (expects 201)
POST {{host}}/api/friendships
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "phoneNumber": "{{phoneB}}"
}

### 4b. Login as user B then list received requests (expects 200 with 1 PENDING)
POST {{host}}/users/login
Content-Type: application/json

{
  "phoneNumber": "{{phoneB}}",
  "password": "test123"
}

> {%
    client.global.set("tokenB", response.body);
%}

### 4c. GET /api/friendships/received as user B (capture first id in {{friendshipId}})
GET {{host}}/api/friendships/received
Authorization: Bearer {{tokenB}}

> {%
    if (response.body && response.body.length > 0) {
        client.global.set("friendshipId", response.body[0].id);
    }
%}

### 4d. Accept the friend request as user B (expects 200, status ACCEPTED)
POST {{host}}/api/friendships/{{friendshipId}}/accept
Authorization: Bearer {{tokenB}}

### 4e. Accept again (expects 409 - already processed)
POST {{host}}/api/friendships/{{friendshipId}}/accept
Authorization: Bearer {{tokenB}}

### 4f. Try to accept as user A (the requester, not the receiver) (expects 404)
POST {{host}}/api/friendships/{{friendshipId}}/accept
Authorization: Bearer {{token}}

### 4g. Try to accept a non-existing friendship (expects 404)
POST {{host}}/api/friendships/00000000-0000-0000-0000-000000000000/accept
Authorization: Bearer {{tokenB}}

### 4h. Register user C (for the decline test)
POST {{host}}/users/register
Content-Type: application/json

{
  "username": "bob",
  "password": "test123",
  "phoneNumber": "{{phoneC}}",
  "email": "bob@test.com"
}

### 4i. Login as user C (stores tokenC)
POST {{host}}/users/login
Content-Type: application/json

{
  "phoneNumber": "{{phoneC}}",
  "password": "test123"
}

> {%
    client.global.set("tokenC", response.body);
%}




### 4j. A sends a friend request to C (expects 201)
POST {{host}}/api/friendships
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "phoneNumber": "{{phoneC}}"
}

### 4k. GET /api/friendships/received as user C (capture first id in {{friendshipIdC}})
GET {{host}}/api/friendships/received
Authorization: Bearer {{tokenC}}

> {%
    if (response.body && response.body.length > 0) {
        client.global.set("friendshipIdC", response.body[0].id);
    }
%}

### 4l. Decline the friend request as user C (expects 200, status DECLINED)
POST {{host}}/api/friendships/{{friendshipIdC}}/decline
Authorization: Bearer {{tokenC}}

### 4m. Decline again (expects 409 - already processed)
POST {{host}}/api/friendships/{{friendshipIdC}}/decline
Authorization: Bearer {{tokenC}}

### 4n. Try to decline as user A (the requester, not the receiver) (expects 404)
POST {{host}}/api/friendships/{{friendshipIdC}}/decline
Authorization: Bearer {{token}}

### 4o. Try to decline a non-existing friendship (expects 404)
POST {{host}}/api/friendships/00000000-0000-0000-0000-000000000000/decline
Authorization: Bearer {{tokenC}}

### 5. Same request again (expects 409 - already pending)
POST {{host}}/api/friendships
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "phoneNumber": "{{phoneB}}"
}

### 6. Send friend request to self (expects 409)
POST {{host}}/api/friendships
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "phoneNumber": "{{phoneA}}"
}

### 7. Send to non-existing phone (expects 404)
POST {{host}}/api/friendships
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "phoneNumber": "+33699999999"
}

### 8. Without token (expects 401)
POST {{host}}/api/friendships
Content-Type: application/json

{
  "phoneNumber": "{{phoneB}}"
}